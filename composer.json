{
  "name": "horizom/app",
  "description": "The lightness PHP framework.",
  "type": "project",
  "version": "5.2.0",
  "homepage": "https://horizom.github.io",
  "license": "MIT",
  "keywords": [
    "horizon",
    "horizom",
    "framework",
    "php"
  ],
  "support": {
    "issues": "https://github.com/horizom/app/issues",
    "source": "https://github.com/horizom/app"
  },
  "authors": [
    {
      "name": "Horizom Team",
      "email": "horizom.team@gmail.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "horizom/core": "^5.2",
    "horizom/http": "^5.2",
    "horizom/routing": "^5.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "php -S localhost:8000 -t public"
    ],
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "php -S localhost:8000 -t public"
    ],
    "test": [
      "php ./vendor/bin/phpunit"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
